<mxfile host="drawio" version="26.0.0">
  <diagram name="system">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1480" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="2" value="gusher.cluster 系統架構（NATS,無 Redis）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="40" as="geometry" />
        </mxCell>

        <mxCell id="10" value="瀏覽器 client（WebSocket,雙向）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="100" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="11" value="整合方／後端（REST 推播）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="20" value="gusher slave 節點 ×N&#xa;持 ws 連線、本機驗 JWT、fan-out&#xa;（內嵌 redisocket 引擎）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="300" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="21" value="gusher master 節點&#xa;publish REST API、查詢在線/頻道&#xa;（無連線;查詢經 request/reply 匯總）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="300" width="340" height="100" as="geometry" />
        </mxCell>

        <mxCell id="30" value="NATS（單一後端）&#xa;&#xa;bus:subject gusher.ch.&lt;appKey&gt;（節點只收訂閱的 channel）&#xa;presence:gusher.presence.query（request/reply 跨節點聚合,無 store）" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="490" y="470" width="500" height="150" as="geometry" />
        </mxCell>

        <mxCell id="50" value="① ws 連線 + JWT&#xa;（auth/subscribe/push 命令）" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=11;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="51" value="② POST /push/&#123;app&#125;/&#123;channel&#125;/&#123;event&#125;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=11;" edge="1" parent="1" source="11" target="21">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="52" value="subscribe gusher.ch.&gt;&#xa;（收推播 → fan-out 給 client）" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=0;entryDx=0;entryDy=0;fontSize=11;" edge="1" parent="1" source="20" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="53" value="③ publish gusher.ch.&lt;app&gt;&#xa;＋ presence request/reply" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;fontSize=11;" edge="1" parent="1" source="21" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="90" value="連線層引擎為 redisocket.v2（Broker/Presence 抽象;NATS 後端）。master/slave 皆為無狀態節點,可水平擴展。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2;fontColor=#333333;" vertex="1" parent="1">
