# NATS (shared backend; the bundled docker-compose.yml uses inline env instead of this file)
GUSHER_NATS_ADDR=nats://nats:4222
GUSHER_PUBLIC_PEM_FILE=/gusher/public.pem
GUSHER_LOG_OUTPUT=stdout
GUSHER_LOG_FORMAT=json

# slave mode
GUSHER_API_LISTEN=:8888
GUSHER_API_URI_PREFIX=/gcs/

## master mode
GUSHER_MASTER_API_LISTEN=:7777
GUSHER_MASTER_URI_PREFIX=/api/
