# NATS (the only backend)
GUSHER_NATS_ADDR=nats://127.0.0.1:4222

# slave mode
GUSHER_API_LISTEN=:8888
GUSHER_API_URI_PREFIX=/gcs/
GUSHER_PUBLIC_PEM_FILE=test/key/public.pem ## rsa public key (verify JWT locally)
GUSHER_WRITE_BUFFER=8192
GUSHER_READ_BUFFER=1024
GUSHER_RECEIVE_MAX_MESSAGE_SIZE=512
# seconds
GUSHER_LOG_SYS_INTERVAL=30
GUSHER_SCAN_INTERVAL=30

## logging
GUSHER_LOG_OUTPUT=stdout   # stdout | file | both
GUSHER_LOG_FORMAT=json     # json | text

# optional NATS auth (path to a .creds file)
# GUSHER_NATS_CREDS=/path/to/app.creds
