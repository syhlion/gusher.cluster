# NATS (the only backend)
GUSHER_NATS_ADDR=nats://127.0.0.1:4222

## master mode
GUSHER_MASTER_API_LISTEN=:7777
GUSHER_PUBLIC_PEM_FILE=test/key/public.pem ## rsa public key (verify JWT)

## logging
GUSHER_LOG_OUTPUT=stdout   # stdout | file | both
GUSHER_LOG_FORMAT=json     # json | text
# GUSHER_LOG_FILE=./gusher.log
# GUSHER_LOG_MAX_SIZE_MB=100
# GUSHER_LOG_MAX_BACKUPS=7
# GUSHER_LOG_MAX_AGE_DAYS=30
# GUSHER_LOG_COMPRESS=false

# optional NATS auth (path to a .creds file)
# GUSHER_NATS_CREDS=/path/to/app.creds
